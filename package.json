{
  "name": "magenim",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "backend:build": "pnpm --filter backend build",
    "backend:start": "pnpm --filter backend start",
    "frontend:test": "pnpm --filter frontend test",
